<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ModalBugRepro.ModalPage"
             BackgroundColor="#DD0000"
             >

    <!-- 
        BUG REPRODUCTION: This modal page has a red background.
        
        BUG 1 - VISUAL GAP: 
        A ~32px blue strip from the MainPage is visible at the very 
        top of the window. The red modal does not cover the full window.
        
        BUG 2 - SMALL UNCLICKABLE AREA:
        If you put Margin="0,-32,0,0" to the first grid on the page, it
        will cover the area, but small area in the middle of the covered
        area is unclickable and doesn't increase the click count.
    -->

    
    <Grid RowDefinitions="Auto,*,Auto" Padding="0">
        <!-- Margin="0,-32,0,0" -->
        <!-- Button at the very top to demonstrate the unclickable area -->
        <Button Text="Try clicking me ! Also please note ⬆ the transparent error area ⬆ above me!"
                Grid.Row="0"
                Clicked="OnTopButtonClicked"
                BackgroundColor="#FFCC00"
                TextColor="Black"
                FontSize="14"
                FontAttributes="Bold"
                CornerRadius="0"
                Margin="0"
                HorizontalOptions="Fill" />

        <!-- Main content -->
        <VerticalStackLayout Grid.Row="1" Spacing="20" VerticalOptions="Center" Padding="30,0">
            <Label Text="Modal Page (Red)"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="White" />

            <Border BackgroundColor="#AA0000" Stroke="Transparent" Padding="20" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🐛 BUG 1 — Visual Gap"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Look at the very top of the window. You should see a blue strip (~32 pixels) from the MainPage showing through. The modal page does not cover the full window. You can fix it with a workaround in ModalPage.xaml.cs."
                           FontSize="14"
                           TextColor="White" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#AA0000" Stroke="Transparent" Padding="20" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🐛 BUG 2 — Small Unclickable Area"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="If you try to fix the problem with another workaround instead, namely, putting Margin 0,-32,0,0 in the first grid, it will indeed cover the transparent area, but a small strip in the covered area will be unclickable and doesn't increase the click count. You can ignore this workaround and problem for now, because the workaround in ModalPage.xaml.cs is a good fix."
                           FontSize="14"
                           TextColor="White" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#AA0000" Stroke="Transparent" Padding="20" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="ℹ️ Click Counter"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="ClickCountLabel"
                           Text="Top button clicked: 0 times"
                           FontSize="16"
                           TextColor="White" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- Pop modal button at the bottom -->
        <Button Text="Pop Modal (Go Back)"
                Grid.Row="2"
                Clicked="OnPopModalClicked"
                BackgroundColor="White"
                TextColor="#DD0000"
                FontSize="18"
                FontAttributes="Bold"
                Margin="30,0,30,30"
                Padding="20,10"
                HorizontalOptions="Fill" />
    </Grid>

</ContentPage>
